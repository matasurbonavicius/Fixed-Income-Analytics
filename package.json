{
  "name": "bond-analytics",
  "version": "0.1.0",
  "description": "A dependency-free TypeScript engine for fixed-income analytics — bond pricing, yield, accrued interest, duration, and portfolio metrics across day-count conventions and financial calendars.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Matas Urbonavičius",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matasurbonavicius/Bond-Analytics.git"
  },
  "homepage": "https://github.com/matasurbonavicius/Bond-Analytics#readme",
  "bugs": {
    "url": "https://github.com/matasurbonavicius/Bond-Analytics/issues"
  },
  "keywords": [
    "bond",
    "fixed-income",
    "finance",
    "yield",
    "ytm",
    "duration",
    "accrued-interest",
    "day-count",
    "valuation",
    "portfolio",
    "quant",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --report-unused-disable-directives",
    "example": "tsx",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0"
  }
}
